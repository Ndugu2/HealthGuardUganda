<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/CardStyle"
    android:layout_margin="@dimen/spacing_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_item_topic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VACCINATION"
            android:textSize="@dimen/text_xs"
            android:textStyle="bold"
            android:textColor="@color/accent_dark"
            android:background="@drawable/bg_tag"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingVertical="@dimen/spacing_xs" />

        <TextView
            android:id="@+id/tv_item_myth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Myth text goes here..."
            android:textSize="@dimen/text_md"
            android:textStyle="italic"
            android:textColor="@color/error"
            android:layout_marginTop="@dimen/spacing_md" />

        <TextView
            android:id="@+id/tv_item_correct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct information goes here..."
            android:textSize="@dimen/text_body"
            android:textColor="@color/on_surface"
            android:layout_marginTop="@dimen/spacing_sm" />

        <TextView
            android:id="@+id/tv_item_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Source: WHO"
            android:textSize="@dimen/text_xs"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="@dimen/spacing_md" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
