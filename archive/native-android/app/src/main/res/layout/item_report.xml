<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/CardStyle"
    android:layout_margin="@dimen/spacing_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_report_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCURATE"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                android:textColor="@color/on_primary"
                android:background="@color/label_accurate"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_report_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026-05-06"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_report_claim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The claim text goes here..."
            android:textSize="@dimen/text_md"
            android:layout_marginTop="@dimen/spacing_md"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_report_confidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confidence: 95%"
            android:textSize="@dimen/text_xs"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="@dimen/spacing_sm" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
