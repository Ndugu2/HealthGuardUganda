{
  "expo": {
    "name": "HealthGuard",
    "slug": "healthguard-uganda",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F1F8E9",
